---
import Page from "../layouts/Page.astro";
import { getPage, getResourceArticles, getSitePages } from "../cms/strapi.js";
import { injectResourceArticles } from "../resourceArticles.js";
import { getSeo } from "../seo.js";

export async function getStaticPaths() {
  const pages = await getSitePages();
  return Object.keys(pages)
    .filter((path) => path !== "/")
    .map((path) => ({
      params: { slug: path.slice(1) },
      props: { path },
    }));
}

const { path } = Astro.props;
const page = await getPage(path);
if (!page?.html || !page?.bodyClass) {
  throw new Error(`Missing source page content for ${path}`);
}
const resourceArticles = path === "/resources" ? await getResourceArticles() : [];
const html = path === "/resources" ? injectResourceArticles(page.html, resourceArticles) : page.html;
const seo = getSeo(path, page.seo);
---
<Page
  path={path}
  bodyClass={page.bodyClass}
  html={html}
  seo={seo}
/>
