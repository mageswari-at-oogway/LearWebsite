---
import Page from "../layouts/Page.astro";
import { getPage } from "../cms/strapi.js";
import { getSeo } from "../seo.js";

const path = "/";
const page = await getPage(path);
const seo = getSeo(path, page?.seo);
---
<Page
  path={path}
  bodyClass={page.bodyClass}
  html={page.html}
  seo={seo}
/>
