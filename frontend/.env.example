# Optional Strapi integration.
# Leave these empty to build from the local Astro content.
STRAPI_URL=https://your-project.strapiapp.com
STRAPI_API_TOKEN=

# Set to true only when the build should fail if Strapi is unavailable.
STRAPI_STRICT=false

# Used for canonical, Open Graph, sitemap and agent-readable files.
PUBLIC_SITE_URL=https://learwebsite.pages.dev

# Contact form email delivery through Cloudflare Pages Functions.
# Brochure downloads are submitted to Formspree: https://formspree.io/f/xkoallnj
# Create a Resend API key and add these in Cloudflare Pages environment variables if using the contact form API.
RESEND_API_KEY=
FORM_OWNER_EMAIL=info@learmedical.com
FORM_FROM_EMAIL="Lear Medical <no-reply@learmedical.com>"
