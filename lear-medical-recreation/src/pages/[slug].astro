---
import Page from "../layouts/Page.astro";
import { injectResourceArticles } from "../resourceArticles.js";
import { sourceBodyClasses, sourcePages } from "../sourcePages.js";

export function getStaticPaths() {
  return Object.keys(sourcePages)
    .filter((path) => path !== "/")
    .map((path) => ({
      params: { slug: path.slice(1) },
      props: { path },
    }));
}

const { path } = Astro.props;
const sourceHtml = sourcePages[path];
const bodyClass = sourceBodyClasses[path];
if (!sourceHtml || !bodyClass) {
  throw new Error(`Missing source page content for ${path}`);
}
const html = path === "/resources" ? injectResourceArticles(sourceHtml) : sourceHtml;
const label = path === "/" ? "" : ` | ${path.slice(1).replace(/-/g, " ")}`;
---
<Page
  path={path}
  bodyClass={bodyClass}
  html={html}
  title={`Lear Medical${label}`}
/>
