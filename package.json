{
  "name": "lear-medical-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 127.0.0.1 --port 5173",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 127.0.0.1 --port 5173",
    "cms:develop": "npm run develop --prefix cms",
    "cms:build": "npm run build --prefix cms",
    "cms:start": "npm run start --prefix cms"
  },
  "engines": {
    "node": ">=20 <=24"
  },
  "dependencies": {
    "astro": "^5.16.4"
  }
}
